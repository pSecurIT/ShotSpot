{
  "name": "shotspot-backend",
  "version": "1.0.1",
  "private": true,
  "license": "BUSL-1.1",
  "description": "Express and PostgreSQL backend for ShotSpot live match capture, reporting, and integrations.",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon",
    "pre-deploy": "node scripts/pre-deploy.js",
    "setup-db": "node scripts/setup-db.js",
    "setup-test-db": "node scripts/setup-test-db.js",
    "migrate": "npm run setup-test-db",
    "check-migrations": "node scripts/check-migrations.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "pretest": "npm run check-migrations && npm run setup-test-db",
    "test": "cross-env NODE_ENV=test jest --config jest.config.js --no-cache --verbose --runInBand",
    "test:watch": "cross-env NODE_ENV=test jest --config jest.config.js --watch --no-cache --verbose",
    "test:coverage": "cross-env NODE_ENV=test jest --config jest.config.js --coverage --no-cache --verbose --runInBand",
    "test:coverage:gate": "node scripts/check-coverage-thresholds.js --threshold=80",
    "test:coverage:strict": "npm run test:coverage && npm run test:coverage:gate",
    "test:ci": "cross-env NODE_ENV=test jest --coverage --ci --watchAll=false --runInBand",
    "test:debug": "cross-env NODE_ENV=test jest --config jest.config.js --no-cache --verbose --detectOpenHandles --forceExit",
    "setup-parallel-dbs": "node scripts/setup-parallel-dbs.js",
    "pretest:parallel": "npm run setup-parallel-dbs",
    "test:parallel": "cross-env NODE_ENV=test jest --config jest.config.parallel.js --no-cache",
    "test:parallel:coverage": "cross-env NODE_ENV=test jest --config jest.config.parallel.js --coverage --no-cache",
    "test:unit": "cross-env NODE_ENV=test jest --config jest.config.unit.js --no-cache --runInBand",
    "test:core-api": "cross-env NODE_ENV=test jest --config jest.config.core-api.js --no-cache --runInBand",
    "test:game-logic": "cross-env NODE_ENV=test jest --config jest.config.game-logic.js --no-cache --runInBand",
    "twizzit:store-credentials": "node scripts/store-twizzit-credentials.js",
    "twizzit:test-connection": "node scripts/test-twizzit-connection.js",
    "twizzit:diagnose": "node scripts/diagnose-twizzit.js",
    "snyk:scan": "snyk test --severity-threshold=high"
  },
  "dependencies": {
    "@dr.pogodin/csurf": "^1.13.0",
    "axios": "^1.16.1",
    "bcrypt": "^6.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "csrf": "^3.1.0",
    "csurf": "npm:@dr.pogodin/csurf@^1.13.0",
    "csv-stringify": "^6.7.0",
    "dotenv": "^17.2.4",
    "express": "^5.1.0",
    "express-rate-limit": "^8.5.2",
    "express-session": "^1.19.0",
    "express-slow-down": "^3.1.0",
    "express-validator": "^7.3.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "nodemailer": "^9.0.1",
    "pdfkit": "^0.18.0",
    "pg": "^8.21.0",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "@babel/core": "^7.28.6",
    "@babel/plugin-syntax-import-attributes": "^7.28.6",
    "@babel/preset-env": "^7.29.7",
    "@eslint/js": "^10.0.1",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.9.3",
    "babel-jest": "^29.7.0",
    "babel-plugin-transform-import-meta": "^2.3.3",
    "cross-env": "^10.1.0",
    "eslint": "^10.0.3",
    "globals": "^17.4.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.3",
    "supertest": "^7.1.4",
    "typescript": "6.0.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "type": "module",
  "overrides": {
    "glob": ">=11.1.0",
    "tar": "6.2.1",
    "minimatch": ">=10.2.1",
    "test-exclude": ">=7.0.1"
  }
}
