{
  "name": "shotspot-frontend",
  "version": "0.1.0",
  "private": true,
  "description": "React and Capacitor frontend for ShotSpot live korfball tracking and reporting.",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@capacitor/android": "^8.0.0",
    "@capacitor/cli": "^8.0.1",
    "@capacitor/core": "^8.0.0",
    "@capacitor/ios": "^8.0.0",
    "@capacitor/splash-screen": "^8.0.0",
    "axios": "^1.13.6",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.0",
    "patch-package": "^8.0.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.13.0",
    "recharts": "^3.7.0",
    "socket.io-client": "^4.8.1"
  },
  "devDependencies": {
    "@eslint/js": "9.39.4",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/jest": "^30.0.0",
    "@types/node": "25.6.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "@vitest/coverage-v8": "4.1.4",
    "axios-mock-adapter": "^2.1.0",
    "cypress": "^15.11.0",
    "del": "^8.0.1",
    "eslint": "9.39.4",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "fake-indexeddb": "^6.2.5",
    "globals": "^17.4.0",
    "jsdom": "29.0.2",
    "start-server-and-test": "^2.1.5",
    "typescript": "6.0.2",
    "typescript-eslint": "8.58.1",
    "vite": "^8.0.8",
    "vitest": "4.1.2"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "coverage": "vitest run --coverage",
    "test:ci": "vitest run --coverage --reporter=verbose",
    "e2e:open": "cypress open",
    "e2e:run": "cypress run",
    "cypress:open": "start-server-and-test dev http://localhost:3000 e2e:open",
    "cypress:run": "start-server-and-test dev http://localhost:3000 e2e:run",
    "test:e2e": "node ./scripts/run-cypress-e2e.mjs",
    "lint": "eslint . --report-unused-disable-directives --max-warnings 2",
    "lint:fix": "eslint . --fix",
    "mobile:sync": "npm run build && npx cap sync",
    "mobile:android": "npm run mobile:sync && npx cap open android",
    "mobile:ios": "npm run mobile:sync && npx cap open ios",
    "mobile:run:android": "npm run mobile:sync && npx cap run android",
    "mobile:run:ios": "npm run mobile:sync && npx cap run ios",
    "postinstall": "patch-package"
  },
  "eslintConfig": {
    "extends": [
      "eslint:recommended",
      "plugin:react/recommended",
      "plugin:react-hooks/recommended",
      "plugin:@typescript-eslint/recommended"
    ]
  },
  "browserslist": [
    ">0.2%",
    "not dead",
    "not op_mini all"
  ],
  "overrides": {
    "glob": ">=11.1.0",
    "tar": "^7.5.11",
    "dompurify": "^3.3.2",
    "minimatch": ">=10.2.1",
    "undici": "7.24.5",
    "yauzl": "^3.2.1"
  }
}
